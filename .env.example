# Unicity API key (testnet2)
# Get yours from the Unicity developer portal: https://developers.unicity.network
UNICITY_API_KEY=your_api_key_here

# Network (testnet2 is the active testnet for the Unicity v2 campaign)
UNICITY_NETWORK=testnet2

# Agent wallet (leave empty to auto-generate on first run)
AGENT_MNEMONIC=

# Agent nametag (registers on first run if not exists)
AGENT_NAMETAG=treasury_bot

# Database (optional — the agent uses in-memory + file storage by default)
DATABASE_URL=postgres://localhost:5432/treasury

# API server port
PORT=3001

# Dashboard base URL (for CORS)
DASHBOARD_URL=http://localhost:3001

# User's Sphere identifier (for DM alerts — e.g. @yourname)
# The agent sends daily reports and alert DMs to this nametag
USER_NAMETAG=
